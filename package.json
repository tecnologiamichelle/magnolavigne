{
  "name": "meupolitico-digital",
  "version": "2.0.0",
  "description": "Plataforma Profissional de Gestão de Campanhas Políticas - Sistema SaaS Multi-tenant",
  "type": "module",
  "author": "MeuPolitico.Digital",
  "license": "Commercial",
  "keywords": ["campanha", "politica", "gestao", "liderancas", "eleitores", "hierarquia", "saas"],
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "dev:d1": "wrangler pages dev dist --d1=meupolitico-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name meupolitico-digital",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000",
    "db:create": "wrangler d1 create meupolitico-production",
    "db:migrate:local": "wrangler d1 migrations apply meupolitico-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply meupolitico-production",
    "db:console:local": "wrangler d1 execute meupolitico-production --local",
    "db:console:prod": "wrangler d1 execute meupolitico-production",
    "git:init": "git init && git add . && git commit -m 'Initial commit - MeuPolitico.Digital V1.0'",
    "git:commit": "git add . && git commit -m",
    "git:status": "git status",
    "git:log": "git log --oneline"
  },
  "dependencies": {
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@hono/vite-cloudflare-pages": "^0.4.2",
    "typescript": "^5.0.0",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
